# ============================================
# Sup! Backend Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/atlas
# 
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
#
# Steps:
# 1. Create account at MongoDB Atlas
# 2. Create a free cluster
# 3. Click "Connect" → "Drivers" → "Node.js"
# 4. Copy the connection string
# 5. Replace <username>, <password>, <cluster> with your values
#
# IMPORTANT: Never commit your actual .env file with real credentials!
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/sup_coming_soon?retryWrites=true&w=majority

# Server Port (default: 5000)
# Railway/Render will override this with their own PORT
PORT=5000

# Environment
NODE_ENV=production

# Frontend URLs for CORS (comma-separated for multiple)
# Add your deployed frontend URL(s) here
FRONTEND_URL=https://your-domain.com,https://www.your-domain.com

# ============================================
# Google OAuth Configuration (Optional)
# ============================================

# Get this from: https://console.cloud.google.com/apis/credentials
#
# Steps:
# 1. Go to Google Cloud Console
# 2. Create a project (or select existing)
# 3. Go to "APIs & Services" → "Credentials"
# 4. Click "Create Credentials" → "OAuth client ID"
# 5. Select "Web application"
# 6. Add authorized JavaScript origins:
#    - http://localhost:5173 (for local dev)
#    - https://your-domain.com (production)
# 7. Copy the Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================
# Email Configuration (Optional - for notifications)
# ============================================

# Your admin email - where notifications will be sent
ADMIN_EMAIL=your@email.com

# Option 1: Gmail (Easiest for personal use)
# 1. Enable 2-factor authentication on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use that password below (not your regular password)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Option 2: SendGrid (Best for production)
# Get API key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.xxx...

# Option 3: Custom SMTP Server
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_password
# SMTP_SECURE=false

# Optional: From email address (defaults to the sending account)
# FROM_EMAIL=noreply@sup.com

# Optional: Admin panel URL for email links
# ADMIN_PANEL_URL=https://your-admin-panel.com

# ============================================
# Admin API Key (REQUIRED for security)
# ============================================
# A strong, random secret used to protect all admin endpoints (GET all data, PUT, DELETE).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_strong_random_secret_here
