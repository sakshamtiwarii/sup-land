# ============================================
# Sup! Frontend Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Backend API URL
# This tells the frontend where to send API requests
#
# Production (update with your deployed backend URL):
VITE_API_URL=https://your-backend-domain.com/api
#
# Alternative: If frontend and backend are on same domain:
# VITE_API_URL=/api

# Google OAuth Client ID (Required for Google Sign-In)
# Get this from: https://console.cloud.google.com/apis/credentials
#
# Steps:
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Click "Create Credentials" → "OAuth client ID"
# 3. Select "Web application"
# 4. Add authorized JavaScript origins:
#    - http://localhost:5173 (for development)
#    - https://your-domain.com (for production)
# 5. Copy the Client ID and paste below
#
# IMPORTANT: This must match the GOOGLE_CLIENT_ID in backend/.env
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
